{
  "manifest_version": 3,
  "name": "WhatsApp Image Reminder",
  "version": "1.0.0",
  "description": "Shows a floating notification to attach images when WhatsApp Web is opened",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
